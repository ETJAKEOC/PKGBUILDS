_basename=ffmpegthumbs
pkgname="${_basename}-git"
pkgver=25.12.2.r2.g405ee80
#pkgver=25.12.2.r58.g8eb38b1
pkgrel=1
pkgdesc='KDE Thumbnailer based on FFmpeg (git build)'
arch=(x86_64)
url="https://invent.kde.org/multimedia/${_basename}"
license=(GPL-2.0-or-later)
depends=(ffmpeg gcc-libs glibc kconfig kcoreaddons kio qt6-base)
makedepends=(extra-cmake-modules-git git)
provides=("${_basename}=${pkgver%.r*}")
conflicts=("${_basename}")
source=("git+${url}.git#branch=release/25.12")
b2sums=('SKIP')
options=('!ccache' '!debug' '!docs' '!emptydirs' 'lto' 'makeflags' '!staticlibs' 'strip' 'buildflags')

pkgver() {
  cd "${_basename}"
  git describe --long | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
  cmake -B build -S "${_basename}" -DBUILD_TESTING=OFF -DQT_MAJOR_VERSION=6
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
