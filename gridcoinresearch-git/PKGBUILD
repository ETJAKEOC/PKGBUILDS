build() {
  cd "$srcdir/$_sourcename"
  mkdir -p build
  cmake -B build -S . \
    -DCMAKE_POLICY_VERSION_MINIMUM=3.5 \
    -DENABLE_GUI=ON \
    -DENABLE_QRENCODE=ON \
    -DUSE_DBUS=ON \
    -DENABLE_UPNP=ON \
    -DDEFAULT_UPNP=ON \
    -DENABLE_PIE=ON \
    -DENABLE_DOCS=OFF \
    -DENABLE_TESTS=OFF \
    -DUSE_QT6=ON \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_COMPILER="clang" \
    -DCMAKE_CXX_COMPILER="clang++"

  cmake --build build
}

package_gridcoinresearch-qt-git() {
  DESTDIR="$pkgdir" cmake --install "$srcdir/$_sourcename/build"
}
