_pkgname=fakeroot
pkgname=fakeroot-git
pkgver=1.14.3.r265.g787d757
pkgrel=1
pkgdesc='Tool for simulating superuser privileges'
arch=('x86_64')
license=('GPL')
url='https://github.com/mackyle/fakeroot'
groups=('base-devel')
depends=('glibc' 'filesystem' 'sed' 'util-linux' 'sh')
makedepends=('systemd' 'po4a')
provides=("$_pkgname")
source=("git+${url}.git" 'clang-build.patch')
sha256sums=('SKIP' 'SKIP')
options=('ccache' '!debug' '!docs' '!emptydirs' 'lto' '!makeflags' '!staticlibs' '!strip' '!buildflags')

pkgver() {
  cd "$_pkgname"
  git describe --long | sed 's/^debian\///;s/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
  cd $_pkgname

  patch -p1 < "$srcdir/clang-build.patch"

  export CC=clang
  export CPP=clang-cpp
  export CXX=clang++
  export LD=lld
  export LLVM_CONFIG=llvm-config
  export CC_LD=lld
  export CXX_LD=lld
  export AR=llvm-ar
  export AS=llvm-as
  export NM=llvm-nm
  export STRIP=llvm-strip
  export OBJCOPY=llvm-objcopy
  export OBJDUMP=llvm-objdump
  export READELF=llvm-readelf
  export RANLIB=llvm-ranlib

  export _COMMON_FLAGS="-march=znver2 -mtune=znver2 -O3 -g0 -pipe -fPIC"
  export CPPFLAGS="$_COMMON_FLAGS"
  export CFLAGS="$_COMMON_FLAGS -D_STAT_VER=0 -D_GNU_SOURCE"
  export CXXFLAGS="$_COMMON_FLAGS -D_STAT_VER=0 -D_GNU_SOURCE"
  export LDFLAGS="-fuse-ld=lld -O3 -lacl"

  ./bootstrap
  ./configure --prefix=/usr --libdir=/usr/lib/libfakeroot \
    --disable-static \
    --enable-shared \
    --with-ipc=sysv \
    --enable-pic

  sed -i 's/#define SETGROUPS_SIZE_TYPE unknown/#define SETGROUPS_SIZE_TYPE gid_t/' config.h

  make -j$(nproc)

  cd .libs
  clang -shared -fPIC -o libfakeroot.so libfakeroot.o libfakeroot_inode64.o libfakeroot_unix2003.o -ldl -lc
}

package() {
  cd $_pkgname
  make DESTDIR="$pkgdir" install
  install -dm0755 "$pkgdir/etc/ld.so.conf.d/"
  echo '/usr/lib/libfakeroot' > "$pkgdir/etc/ld.so.conf.d/fakeroot.conf"

  echo "===================================================================="
  echo "The install will fail if you don't already have a working fakeroot"
  echo "You need to do these steps manually:"
  echo "cd src/fakeroot"
  echo "sudo make install"
  echo "===================================================================="
}
