arch=('x86_64')
pkgver=23.0.0.r4295
pkgrel=1
pkgname=('llvm-ETJAKEOC')
pkgbase=llvm-project-git
pkgdesc="Meta LLVM/Clang stack: Clang, libc++, libc++abi, libunwind, lld, compiler-rt, clang-tools-extra, llvm-spirv, BOLT"
url="https://llvm.org/"
license=('Apache-2.0 WITH LLVM-exception')
provides=('llvm-libs-git' 'llvm-libs' 'llvm-git' 'llvm' 'clang-git' 'clang' 'compiler-rt-git' 'compiler-rt' 'lld-git' 'lld' 'clang-tools-extra-git' 'clang-tools-extra' 'libcxx-git' 'libcxx' 'libcxxabi-git' 'libcxxabi' 'libunwind-git' 'libunwind' 'llvm-spirv-git' 'llvm-spirv' 'bolt-git' 'bolt')
conflicts=($provides)
makedepends=('git' 'cmake' 'ninja' 'python' 'python-setuptools' 'libffi' 'libedit' 'ncurses' 'libxml2' 'opencl-headers' 'z3' 'zstd')
depends=('zlib' 'zstd' 'libffi' 'libedit' 'ncurses' 'libxml2')
source=("git+https://github.com/llvm/llvm-project.git#branch=main" "libunwind.pc")
sha512sums=('SKIP' 'SKIP')
options=('!ccache' '!debug' '!docs' '!emptydirs' '!lto' '!makeflags' '!staticlibs' 'strip' '!buildflags')

pkgver() {
  cd "$srcdir/llvm-project"
  _pkgver=$(git describe --tags | sed 's/^llvmorg-//; s/-init//; s/\([^-]*-g\)/0.0.r\1/; s/-/./g; s/\.g[0-9a-f]\{7,14\}$//')
  echo "${_pkgver}"
}

prepare() {
  cd "$srcdir/llvm-project"
  git submodule update --init --recursive
}

ulimit -s unlimited
_CPU="znver2"
_flags=(
  # Base config
  -G Ninja
  -Wno-dev
  -Wno-deprecated
  -Wno-error=dev
  -Wno-error=deprecated
  -DCMAKE_BUILD_TYPE=Release
  -DCMAKE_INSTALL_PREFIX="/usr"
  -DCMAKE_INSTALL_LIBDIR="lib"
  -DLLVM_INSTALL_PACKAGE_DIR="lib/cmake/llvm"
  -DCMAKE_INSTALL_RPATH_USE_LINK_PATH=ON
  -DCMAKE_INTERPROCEDURAL_OPTIMIZATION=OFF

  # Toolchain
  -DCMAKE_C_COMPILER="clang"
  -DCMAKE_CXX_COMPILER="clang++"
  -DCMAKE_CXX_STANDARD="17"
  -DLLVM_USE_LINKER="lld"
  -DLLVM_CCACHE_BUILD=OFF

  -DLLVM_DEFAULT_TARGET_TRIPLE=x86_64-pc-linux-gnu
  -DLLVM_HOST_TRIPLE=x86_64-pc-linux-gnu
  -DLLVM_TARGET_TRIPLE=x86_64-pc-linux-gnu
  -DCMAKE_C_COMPILER_TARGET=x86_64-pc-linux-gnu
  -DCMAKE_CXX_COMPILER_TARGET=x86_64-pc-linux-gnu
  -DCMAKE_ASM_COMPILER_TARGET=x86_64-pc-linux-gnu

  -DCMAKE_C_FLAGS_RELEASE="-march=$_CPU -mtune=$_CPU -pipe"
  -DCMAKE_CXX_FLAGS_RELEASE="-march=$_CPU -mtune=$_CPU -pipe"
  -DCMAKE_C_FLAGS="-Wno-error -pipe"
  -DCMAKE_CXX_FLAGS="-Wno-error -pipe"
  -DCMAKE_EXE_LINKER_FLAGS="-fuse-ld=lld"

  # Projects, Targets, Runtimes
  -DLIBCLC_TARGETS_TO_BUILD="amdgcn--;amdgcn-amd-amdhsa-llvm;amdgcn-mesa-mesa3d;clspv--"
  -DLLVM_ENABLE_PROJECTS="bolt;clang;clang-tools-extra;lld;llvm"
  -DLLVM_ENABLE_RUNTIMES="libunwind;compiler-rt;libclc"
  -DLLVM_TARGETS_TO_BUILD="X86;AMDGPU;SPIRV;AArch64;ARM;WebAssembly;RISCV;BPF"

  # Build behavior
  -DLLVM_PARALLEL_LINK_JOBS=2
  -DLLVM_ENABLE_LTO=ON

  # Shared libs
  -DLLVM_LINK_LLVM_DYLIB=ON
  -DLLVM_BUILD_LLVM_DYLIB=ON
  -DCLANG_LINK_CLANG_DYLIB=ON
  -DLIBUNWIND_ENABLE_SHARED=ON

  # Compiler RT
  -DCOMPILER_RT_DEFAULT_TARGET_ONLY=ON
  -DCOMPILER_RT_BUILD_BUILTINS=ON
  -DCOMPILER_RT_BUILD_SANITIZERS=ON
  -DCOMPILER_RT_BUILD_PROFILE=ON
  -DCOMPILER_RT_BUILD_XRAY=OFF
  -DCOMPILER_RT_BUILD_LIBFUZZER=OFF
  -DCOMPILER_RT_BUILD_MEMPROF=OFF
  -DCOMPILER_RT_SKIP_RUNTIME_CHECKS=ON

  # Enable features
  -DLLVM_ENABLE_ASSERTIONS=OFF
  -DLLVM_ENABLE_EH=ON
  -DLLVM_ENABLE_FFI=ON
  -DLLVM_ENABLE_LIBXML2=ON
  -DLLVM_ENABLE_PIC=ON
  -DLLVM_ENABLE_RTTI=ON
  -DLLVM_ENABLE_THREADS=ON
  -DLLVM_ENABLE_ZLIB=ON
  -DLLVM_ENABLE_ZSTD=ON

  -DLIBUNWIND_INSTALL_LIBRARY=ON
  -DLLVM_INSTALL_BINUTILS_SYMLINKS=ON
  -DLLVM_INSTALL_CCTOOLS_SYMLINKS=ON
  -DLLVM_INSTALL_UTILS=ON

  -DLLVM_USE_HOST_TOOLS=OFF
  -DLLVM_USE_SPLIT_DWARF=OFF

  # Disable features
  -DCLANG_ENABLE_STATIC_ANALYZER=OFF
  -DLLVM_BUILD_BENCHMARKS=OFF
  -DLLVM_BUILD_DOCS=OFF
  -DLLVM_BUILD_EXAMPLES=OFF
  -DLLVM_BUILD_TESTS=OFF
  -DLLVM_ENABLE_BINDINGS=OFF
  -DLLVM_ENABLE_DUMP=OFF
  -DLLVM_ENABLE_EXPENSIVE_CHECKS=OFF
  -DLLVM_ENABLE_Z3_SOLVER=OFF
  -DLLVM_INCLUDE_BENCHMARKS=OFF
  -DLLVM_INCLUDE_DOCS=OFF
  -DLLVM_INCLUDE_EXAMPLES=OFF
  -DLLVM_INCLUDE_TESTS=OFF
)

build() {
  cmake -B "$srcdir/_build" -S "$srcdir/llvm-project/llvm" "${_flags[@]}"
  cmake --build "$srcdir/_build"
}

package() {
    DESTDIR="$pkgdir" ninja -C "$srcdir/_build" install
    mkdir -p "$pkgdir/usr/lib/pkgconfig"
    cp -P "$srcdir"/_build/lib/lib{LLVM,LTO,Remarks}*.so* "$pkgdir/usr/lib/"
    cp "$srcdir/libunwind.pc" "$pkgdir/usr/lib/pkgconfig/libunwind.pc"
}
