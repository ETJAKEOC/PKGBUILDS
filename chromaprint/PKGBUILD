pkgname=chromaprint
pkgver=1.6.0
pkgrel=2
pkgdesc="Library for extracting fingerprints from any audio source"
url="https://acoustid.org/chromaprint"
arch=('x86_64')
license=('LGPL-2.1-or-later' 'MIT')
depends=(gcc-libs glibc)
makedepends=(cmake ffmpeg git gtest)
provides=('libchromaprint.so')
source=(git+https://github.com/acoustid/chromaprint.git chromaprint-use-system-gtest.patch)
sha512sums=('SKIP' '2466d8b84fb72c3d6e2e53c2ec9619533774be75fbfb002c63d2d530775bf98189951c8467a652882280d77a8ef7f22488e2ab4ae1b5ddd70a4914143d9bc3a6')

prepare() {
  patch -d $pkgname -p1 < chromaprint-use-system-gtest.patch
}

build() {
  cmake -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE='None' \
        -DBUILD_TESTS=ON \
        -DBUILD_TOOLS=ON \
        -Wno-dev \
        -B build \
        -S $pkgname
  cmake --build build
}

check() {
  cmake --build build --target test
}

package() {
  depends+=('libavcodec.so' 'libavformat.so' 'libavutil.so' 'libswresample.so')
  DESTDIR="$pkgdir" cmake --install build
  install -vDm 644 $pkgname/LICENSE.md -t "$pkgdir/usr/share/licenses/$pkgname"
  install -vDm 644 $pkgname/{NEWS.txt,README.md} -t "$pkgdir/usr/share/doc/$pkgname"
}
